# Canonical production origin used for SEO metadata.
VITE_SITE_URL=https://novatech.et

# Public contact channels. Set these before launch if the defaults change.
VITE_CONTACT_EMAIL=nahomgwmichael@gmail.com
VITE_CONTACT_PHONE_DISPLAY=+251 911 000 000
VITE_CONTACT_PHONE_HREF=tel:+251911000000
VITE_WHATSAPP_NUMBER=251911000000
VITE_TELEGRAM_HANDLE=@NovaTechET
VITE_TELEGRAM_URL=https://t.me/NovaTechET
VITE_LINKEDIN_URL=https://www.linkedin.com/company/novatech-et/
VITE_LOCATION_LABEL=Addis Ababa, Ethiopia
VITE_MAPS_URL=https://maps.google.com/?q=Addis%20Ababa%2C%20Ethiopia

# Optional API endpoint for contact form submissions.
# If missing, the homepage form falls back to a prefilled mailto flow.
VITE_CONTACT_API_ENDPOINT=

# Optional API key sent as X-Api-Key with contact submissions.
VITE_CONTACT_API_KEY=

# Optional timeout for contact API requests (milliseconds).
VITE_CONTACT_TIMEOUT_MS=9000

# Optional custom analytics endpoint.
# Events continue to publish to gtag/dataLayer when available.
VITE_ANALYTICS_ENDPOINT=

# Optional pricing data endpoint.
# Expected response shape: { "webPackages": [ ... ] }
# If absent or invalid, static pricing data is used.
VITE_PRICING_DATA_ENDPOINT=

# Optional SiteSpeak bot identifier used by the live chat dock.
# If omitted, the built-in default bot ID is used.
VITE_SITESPEAK_BOT_ID=
